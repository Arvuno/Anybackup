FROM node:22-alpine AS build

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

ARG VITE_AUTH_SERVICE_BASE_PATH=/api/auth_service/v1
ARG VITE_AUTH_REALM=master
ARG VITE_AUTH_CLIENT_ID=admin-cli
ARG VITE_AUTH_SCOPE=openid
ARG VITE_AUTH_ADMIN_ROLE_NAME=backup_admin

ENV VITE_AUTH_SERVICE_BASE_PATH=${VITE_AUTH_SERVICE_BASE_PATH}
ENV VITE_AUTH_REALM=${VITE_AUTH_REALM}
ENV VITE_AUTH_CLIENT_ID=${VITE_AUTH_CLIENT_ID}
ENV VITE_AUTH_SCOPE=${VITE_AUTH_SCOPE}
ENV VITE_AUTH_ADMIN_ROLE_NAME=${VITE_AUTH_ADMIN_ROLE_NAME}

RUN npm run build

FROM nginx:1.30-alpine

ENV AUTH_SERVICE_UPSTREAM=http://192.168.40.107:80
ENV CONVERSATION_SERVICE_UPSTREAM=http://192.168.40.107:80
ENV NGINX_ENVSUBST_FILTER=AUTH_SERVICE_UPSTREAM|CONVERSATION_SERVICE_UPSTREAM

COPY ops/nginx/default.conf.template /etc/nginx/templates/default.conf.template
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
