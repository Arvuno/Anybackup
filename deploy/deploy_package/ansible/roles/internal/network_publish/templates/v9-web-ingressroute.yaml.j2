apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: agent-web
  namespace: {{ deployment_namespace }}
  labels:
    app.kubernetes.io/name: agent-web
    app.kubernetes.io/part-of: v9
  annotations:
    kubernetes.io/ingress.class: traefik
spec:
  routes:
    - kind: Rule
      match: PathPrefix(`{{ network_public_web_contract.public_path }}`)
      priority: 1
      services:
        - name: {{ network_public_web_contract.resource_name }}
          port: {{ network_public_web_contract.service_port | int }}
